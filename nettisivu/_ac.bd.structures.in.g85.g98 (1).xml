    <mn>85</mn>
   </msub>
   <mo>)</mo>
  </mrow>
  <mn>2</mn>
 </msup>
</math></span>(<span style='font-style: italic;color: #FF80FF;'>a</span>) and <span><math xmlns='http://www.w3.org/1998/Math/MathML'
    mathematica:form='TraditionalForm'
